generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Software {
  id          String       @id @default(cuid())
  name        String
  type        SoftwareType
  slug        String       @unique
  location    String
  description String?
  logoUrl     String?      @map("logo_url")
  urls        Json

  status   SoftwareStatus @default(PRE_REVIEWED)
  analysis Analysis?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  runs      Run[]

  @@map("softwares")
}

enum SoftwareStatus {
  PRE_REVIEWED
  PROCESSING
  PROCESSED
  ACTIVE
  FAILED
}

enum SoftwareType {
  WEB
  MOBILE
  CLI
  OS
  UTIL
}

model Analysis {
  id String @id @default(cuid())

  softwareId String   @unique @map("software_id")
  software   Software @relation(fields: [softwareId], references: [id])

  quickTake String  @map("quick_take")
  verdict   Verdict
  riskScore Int     @map("risk_score")

  redFlags    String[] @map("red_flags")
  yellowFlags String[] @map("yellow_flags")
  greenFlags  String[] @map("green_flags")

  whatMatters     String[] @map("what_matters")
  dataFlow        String[] @map("data_flow")
  featurePolicies String[] @map("feature_policies")

  bestPractices String[] @map("best_practices")
  badPractices  String[] @map("bad_practices")

  reviewed    Boolean  @default(false)
  version     String?
  generatedAt DateTime @default(now()) @map("generated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("analysis")
}

enum Verdict {
  SAFE
  CAUTION
  HIGH_RISK
}

model Run {
  id String @id @default(cuid())

  softwareId String   @map("software_id")
  software   Software @relation(fields: [softwareId], references: [id], onDelete: Cascade)

  status RunStatus @default(PENDING)

  stage1 Json? @map("stage_1")
  stage2 Json? @map("stage_2")
  stage3 Json? @map("stage_3")
  final  Json?

  logs  String?
  error String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")

  @@index([status])
  @@map("runs")
}

enum RunStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}
